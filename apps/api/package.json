{
  "name": "@wordle-royale/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS backend/API skeleton for Wordle Royale.",
  "type": "module",
  "main": "dist/apps/api/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "pnpm run typecheck && tsc -p tsconfig.build.json && node scripts/link-built-workspace-packages.mjs",
    "start": "node dist/apps/api/src/main.js",
    "smoke:prod-start": "node ../../scripts/api-prod-start-smoke.mjs",
    "test": "node --import tsx --test prisma/*.test.mjs test/*.test.ts",
    "test:rating-reads:postgres": "node --import tsx --test test/standard-rating-read-integration.test.ts",
    "test:speed-rating:postgres": "node --import tsx --test test/speed-rating-postgres.integration.test.ts",
    "test:postgres:matchmaking": "node scripts/run-matchmaking-postgres-integration.mjs",
    "test:postgres:speed-gameplay": "node scripts/run-speed-gameplay-postgres-integration.mjs",
    "test:postgres:speed-timing": "node scripts/run-speed-timing-postgres-integration.mjs",
    "db:validate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://wordle:***@localhost:5432/wordle_royale_local?schema=public}\" prisma validate --schema prisma/schema.prisma",
    "db:generate": "DATABASE_URL=\"${DATABASE_URL:-postgresql://wordle:***@localhost:5432/wordle_royale_local?schema=public}\" prisma generate --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed:dry-run": "tsx prisma/seed-fixtures.ts --dry-run --json",
    "db:seed:local": "tsx prisma/seed-fixtures.ts --apply",
    "db:bootstrap:preview-dictionary": "tsx prisma/bootstrap-preview-dictionary.ts",
    "test:postgres:preview-dictionary": "node scripts/run-preview-dictionary-postgres-integration.mjs",
    "db:reset:ranked-smoke": "node ../../scripts/reset-ranked-smoke-db.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/client": "^6.10.1",
    "@wordle-royale/contracts": "workspace:*",
    "@wordle-royale/fixtures": "workspace:*",
    "@wordle-royale/game-engine": "workspace:*",
    "@wordle-royale/word-tools": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.9",
    "@types/node": "^24.10.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^6.10.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
