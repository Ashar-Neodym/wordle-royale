# Wordle Royale local environment template
# Copy to .env.local for local development. Do not commit .env.local.
# Values marked <...> are placeholders. Use local-only disposable values.

APP_ENV=local
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000/api/v1
WS_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Host/database match docker-compose.yml; password is intentionally redacted.
DATABASE_URL=postgresql://wordle:***@localhost:5432/wordle_royale_local?schema=public
DATABASE_DIRECT_URL=postgresql://wordle:***@localhost:5432/wordle_royale_local?schema=public
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=wr:local

AUTH_MODE=dev_stub
ENABLE_DEV_AUTH=true
ENABLE_DEV_ROUTES=true
JWT_ACCESS_SECRET=<local-development-secret>
REFRESH_TOKEN_PEPPER=<local-development-secret>
PASSWORD_HASH_PEPPER=<local-development-secret>
COOKIE_DOMAIN=
COOKIE_SECURE=false
CSRF_SECRET=<local-development-secret>

SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=local
OTEL_EXPORTER_OTLP_ENDPOINT=

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WS_BASE_URL=http://localhost:4000

# Only set locally if running EAS commands. Never commit a real token.
EXPO_TOKEN=
