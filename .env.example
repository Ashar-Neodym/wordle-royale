# Wordle Royale environment template
# Copy to environment-specific secret stores or local .env files as needed.
# Do not put real production secrets in this file.

# Runtime
APP_ENV=local
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
WS_BASE_URL=http://localhost:4000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Local data services. Host/database match docker-compose.yml; password is intentionally redacted.
DATABASE_URL=postgresql://wordle:***@localhost:5432/wordle_royale_local?schema=public
# Some managed providers require a separate direct URL for migrations. Local dev can reuse DATABASE_URL.
DATABASE_DIRECT_URL=postgresql://wordle:wordle_local_password@localhost:5432/wordle_royale_local?schema=public
REDIS_URL=redis://localhost:6379
# Hosted preview may leave Redis unset with REDIS_REQUIRED=false if Redis is not product-critical.
REDIS_REQUIRED=true
REDIS_KEY_PREFIX=wr:local

# Standard matchmaking interactive-transaction budgets (bounded in code).
# Defaults: maxWait=5000ms, timeout=20000ms. Allowed: 1000–10000ms and 6000–30000ms.
MATCHMAKING_TRANSACTION_MAX_WAIT_MS=5000
MATCHMAKING_TRANSACTION_TIMEOUT_MS=20000

# Automatic ranked queues. Standard remains enabled by default; Speed is fail-closed unless explicitly enabled.
STANDARD_1V1_QUEUE_ENABLED=true
SPEED_1V1_QUEUE_ENABLED=false

# Auth/security placeholders — replace per environment outside git.
AUTH_MODE=dev_stub
# Preview-only explicit demo sessions use AUTH_MODE=preview_demo_session with dev flags disabled.
PREVIEW_DEMO_SESSION_TTL_SECONDS=7200
ENABLE_DEV_AUTH=true
ENABLE_DEV_ROUTES=true
JWT_ACCESS_SECRET=replace-with-local-development-secret
REFRESH_TOKEN_PEPPER=replace-with-local-development-secret
PASSWORD_HASH_PEPPER=replace-with-local-development-secret
COOKIE_DOMAIN=
COOKIE_SECURE=false
CSRF_SECRET=replace-with-local-development-secret

# Observability placeholders
SENTRY_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_RELEASE=local
OTEL_EXPORTER_OTLP_ENDPOINT=

# Expo/mobile public config
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_WS_BASE_URL=http://localhost:4000

# EAS/CI token placeholder. Never commit a real token.
EXPO_TOKEN=
